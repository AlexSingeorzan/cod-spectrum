.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
.DS_Store
cod_spectrum.db
data/frames/*
data/crops/*
data/clips/*
data/reports/*
!data/frames/.gitkeep
!data/crops/.gitkeep
!data/clips/.gitkeep
!data/reports/.gitkeep
# large downloaded VODs stay local; verified evidence crops are tracked
data/videos/lat_van.mp4
!data/crops/lat_van_hp/
# precomputed minimap heatmaps (need the local VOD to rebuild)
!data/reports/lat_van_hp_minimap.json
# YOLO dataset images/labels are regenerable; keep only data.yaml + README
data/minimap_dataset/images/
data/minimap_dataset/labels/
# killfeed dataset: bulky region-context crops rebuild from the VOD; keep the small
# row crops to label + manifest + annotations
data/killfeed_dataset/regions/
# panel counter: evidence panel crops rebuild from the VOD; keep readings cache +
# events + manifest + eval so the eval runs offline
data/panel_counter/crops/
